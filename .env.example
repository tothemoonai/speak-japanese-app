ZHIPU_API_KEY=641fa29c9b834af594641e33eb657275.bX10Fjr1kBwlK3im

# VolcEngine ASR (火山引擎语音识别)
NEXT_PUBLIC_VOLCENGINE_APP_ID=7063204876
NEXT_PUBLIC_VOLCENGINE_ACCESS_TOKEN=U8PJF_OmQKQGzHETV3ZCrwW1_mmiqkRV
# 模型选择 (可选，默认为模型1.0)
# volc.bigasr.auc - 录音文件识别模型1.0 (默认可用)
